{
    "name": "vscode-qprompt-dsl",
    "description": "The extension specific package",
    "version": "0.0.1",
    "displayName": "qprompt-dsl",
    "type": "module",
    "engines": {
        "vscode": "^1.91.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "qprompt",
            "aliases": ["Qprompt", "qprompt"],
            "extensions": [".qprompt"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "qprompt",
            "scopeName": "source.qprompt",
            "path": "syntaxes/qprompt.tmLanguage.json"
        }]
    },
    "activationEvents": [
        "onLanguage:qprompt"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "npm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/qprompt.tmLanguage.json ./syntaxes/qprompt.tmLanguage.json",
        "build": "npm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
        "build:clean": "npm run clean && npm run build",
        "watch": "npm run build:prepare && concurrently -n tsc,esbuild -c blue,yellow \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\""
    },
    "dependencies": {
        "qprompt-language": "0.0.1",
        "vscode-languageclient": "~10.0.1",
        "vscode-languageserver": "~10.0.1"
    },
    "devDependencies": {
        "@types/vscode": "~1.91.0",
        "concurrently": "~10.0.3",
        "esbuild": "~0.28.1"
    },
    "vsce": {
      "dependencies": false
    }
}
