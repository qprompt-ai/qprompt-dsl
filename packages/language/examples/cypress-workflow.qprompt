// Full Cypress test-generation agent graph: plan -> validate the plan ->
// generate code -> reject non-Cypress APIs
// -> lint the code -> run it, with debug/retry loops at each checkpoint.
// Mirrors a hand-written LangGraph StateGraph pipeline.
graph: CypressTestGeneration

states:

  // Shared by every agent for overall pipeline control (routing).
  agent_state:
    failed: false
    error: null
    phase: null
    details?: null

  // Used only by validator-kind agents (planValidator, syntaxvalidator),
  // in addition to agent_state — they associate with both, so they get
  validation_state:
    rule?: null
    reason?: null

resources:

  testPlanStrategies:
    type: knowledge_base
    paths:
      - https://martinfowler.com/articles/practical-test-pyramid.html
      - https://martinfowler.com/bliki/TestStrategy.html
      - https://en.wikipedia.org/wiki/Boundary-value_analysis
      - https://en.wikipedia.org/wiki/Equivalence_partitioning
    rag:
      loader: web
      splitter: recursive
      // Larger chunks -> reasoning over strategy, not code lookup
      chunk_size: 1000
      chunk_overlap: 150

      embeddings:
        provider: huggingface
        model: sentence-transformers/all-MiniLM-L6-v2

      vector_store:
        type: faiss
        persist_path: .rag/test-plan-strategies

      retrieval:
        strategy: mmr
        top_k: 2

  cypressDocs:
    type: knowledge_base
    paths:
      - https://docs.cypress.io
      - https://docs.cypress.io/api
      - https://docs.cypress.io/guides
    rag:
      loader: web
      splitter: recursive
      chunk_size: 400
      chunk_overlap: 50

      embeddings:
        provider: huggingface
        model: sentence-transformers/all-MiniLM-L6-v2

      vector_store:
        type: faiss
        persist_path: .rag/cypress/docs

      retrieval:
        strategy: similarity
        top_k: 4

  cypressBestPractices:
    type: knowledge_base
    paths:
      - https://docs.cypress.io/guides/references/best-practices
      - https://docs.cypress.io/guides/references/assertions
      - https://docs.cypress.io/guides/references/trade-offs
      - https://docs.cypress.io/faq/questions/using-cypress-faq
    rag:
      loader: web
      splitter: recursive
      // Larger chunks -> conceptual coherence over exact API snippets
      chunk_size: 800
      chunk_overlap: 100

      embeddings:
        provider: huggingface
        model: sentence-transformers/all-MiniLM-L6-v2

      vector_store:
        type: faiss
        persist_path: .rag/cypress/best-practices

      retrieval:
        strategy: mmr // diversity over precision
        top_k: 3

  cypressApiDocs:
    type: knowledge_base
    paths:
      - https://docs.cypress.io/api/commands/visit
      - https://docs.cypress.io/api/commands/get
    rag:
      loader: web
      splitter: recursive
      chunk_size: 400
      chunk_overlap: 50
      embeddings:
        provider: huggingface
        model: sentence-transformers/all-MiniLM-L6-v2
      vector_store:
        type: faiss
        persist_path: .rag/cypress/api
      retrieval:
        strategy: similarity
        top_k: 4

  cypressErrorsFaq:
    type: knowledge_base
    paths:
      - https://docs.cypress.io/faq/questions/using-cypress-faq
    rag:
      loader: web
      splitter: recursive
      chunk_size: 400
      chunk_overlap: 50
      embeddings:
        provider: huggingface
        model: sentence-transformers/all-MiniLM-L6-v2
      vector_store:
        type: faiss
        persist_path: .rag/cypress/errors-faq
      retrieval:
        strategy: similarity
        top_k: 3

models:
  // `mode` (finetuned/lora/base) describes which checkpoint a docker
  // model runner serves, so it belongs here, not on each agent that
  // happens to use it — a separate Model entry per checkpoint/port also
  // lets different agents pick different variants of the same base
  // model. (Only docker-served models for now; ollama/other runtime
  // selection is future work.)
  qwen3_finetuned:
    image: ai/qwen3:14B-Q6_K
    serving_backend: vllm
    port: 8080
    mode: finetuned

  qwen3_lora:
    image: ai/qwen3:14B-Q6_K
    serving_backend: vllm
    port: 8081
    mode: lora

agents:

  testplanner:
    kind: llm
    model: qwen3_finetuned
    description: "Turns the user's request into a plain-English, step-by-step test plan."
    input: true
    output: true
    // Output format text
    temperature: 0.0
    context:
      - testPlanStrategies
    state: agent_state
    prompt: """
      You are a meticulous test planning expert for cypress. Create a
      detailed, step-by-step, textual plan based solely on the user's request.
      No code. Use plain English. Follow the request's terminology exactly.
      Output format:
        Title: <summary>
        Objective: <goal>
        Steps:
          1. ...
    """

  planValidator:
    kind: rules_engine
    description: "Validates planner output without invoking an LLM."
    // Takes the plan as input but has no data output of its own — it
    // only ever reports pass/fail (and why) via emit_state.
    input: true
    output: false
    rules:
      - id: no_code
        check: not_contain
        values:
          - "cy."
          - "describe("
          - "it("
        message: "Planner output contains code."
      - id: structure
        check: structure
        start_with: "Title:"
        must_contain:
          - "Steps:"
        message: "Planner output missing required structure."
    state:
      - agent_state
      - validation_state
    emit_state:
      on_pass:
        failed: false
        phase: "plan"
      on_fail:
        failed: true
        phase: "plan"
        rule: "$rule.id"
        reason: "$rule.message"

  cygenerator:
    kind: llm
    model: qwen3_lora
    description: "Converts a validated plan into executable Cypress code."
    input: true
    output: true
    // Ouput format code ts
    context:
      - cypressDocs
      - cypressBestPractices
    state: agent_state
    prompt: """
      You are an expert cypress test developer. Convert the provided
      textual plan into valid, executable, syntactically correct {output_format}
      code.
      CRITICAL RULES:
        - Follow the plan and request precisely.
        - Use exact selectors if specified.
        - cy.visit() must be standalone.
        - Begin the file with: /// <reference types="cypress" />
        - Output only code, no explanations.
    """

  cypressApiValidator:
    kind: rules_engine
    description: "Rejects generated code that uses Playwright/WebDriver-style APIs instead of Cypress."
    input: true
    output: false
    rules:
      - id: no_foreign_apis
        check: not_contain
        values:
          - "page."
          - "browser."
          - "await "
          - "chromium"
          - "firefox"
          - "webkit"
          - "playwright"
        message: "Generated code uses non-Cypress (Playwright/WebDriver-style) APIs."
    state:
      - agent_state
      - validation_state
    emit_state:
      on_pass:
        failed: false
        phase: "cypress_api_check"
      on_fail:
        failed: true
        phase: "cypress_api_check"
        rule: "NON_CYPRESS_API"
        reason: "$rule.message"

  syntaxvalidator:
    // "container": this agent's real work happens by running a tool
    // (the cypress-validator image, TypeScript + ESLint) inside Docker.
    kind: container
    description: "Validates generated Cypress code with TypeScript and ESLint via the cypress-validator image (github.com/.../syntax-validator)."
    // Only reports pass/fail via emit_state, no data output of its own.
    input: true
    output: false
    image: cypress-validator
    command: ""
    state:
      - agent_state
      - validation_state
    emit_state:
      on_pass:
        failed: false
        phase: "lint"
      on_fail:
        failed: true
        phase: "lint"
        // Derived by the runtime from the tool's JSON report (see
        // validation-report.schema.json): "SYNTAX" when
        // summary.typescriptErrors > 0, else "STYLE" when
        // summary.eslintErrors/eslintWarnings > 0 — not a literal field
        // on the report, since the report has no single "category".
        rule: "$report.failureCategory"
        details: "$report.categories"

  cypressExec:
    kind: container
    description: "Executes the generated Cypress test inside Docker."
    input: true
    output: true
    image: cypress/included
    command: "npx cypress run"
    state: agent_state
    emit_state:
      on_pass:
        failed: false
        phase: "execution"
      on_fail:
        failed: true
        phase: "execution"
        details: "$cypress.output"

  cydebugger:
    kind: llm
    model: qwen3_finetuned
    description: "Repairs a plan or code that failed a downstream checkpoint."
    input: true
    output: true
    context:
      - cypressApiDocs
      - cypressErrorsFaq
    state: agent_state
    prompt: """
      You are an expert cypress debugger. Given the original request,
      the current (broken) plan or code, and the failure reason, produce a
      corrected version using only official Cypress APIs.
    """

workflows:
  cypressFlow:
    channels:
      given_query: txt
      test_plan: txt
      test_script: ts
      test_results: json

    steps:
      - name: planTest
        kind: plan
        agent: testplanner
        subscribe:
          - given_query
        publish:
          - test_plan

      - name: validatePlan
        kind: validate
        agent: planValidator
        subscribe:
          - test_plan
        routes:
          - if: "state.failed && state.rule == 'no_code'" then: planFix
          - if: "state.failed" then: planFixDefault
          - if: "!state.failed" then: genCode

      - name: planFix
        kind: debug
        agent: cydebugger
        subscribe:
          - test_plan
        publish:
          - test_plan
        on_complete: planTest

      - name: planFixDefault
        kind: debug
        agent: cydebugger
        subscribe:
          - test_plan
        publish:
          - test_plan
        on_complete: planTest

      - name: genCode
        kind: generate
        agent: cygenerator
        subscribe:
          - test_plan
        publish:
          - test_script
        retry: 3

      - name: checkCypressApi
        kind: validate
        agent: cypressApiValidator
        subscribe:
          - test_script
        routes:
          - if: "state.failed" then: debugNonCypressApi
          - if: "!state.failed" then: lint

      - name: debugNonCypressApi
        kind: debug
        agent: cydebugger
        subscribe:
          - test_script
        publish:
          - test_script
        on_complete: checkCypressApi

      - name: lint
        kind: validate
        agent: syntaxvalidator
        subscribe:
          - test_script
        routes:
          - if: "state.failed && state.rule == 'SYNTAX'" then: debugSyntaxError
          - if: "state.failed && state.rule == 'STYLE'" then: debugStyleError
          - if: "!state.failed" then: runTests

      - name: debugSyntaxError
        kind: debug
        agent: cydebugger
        subscribe:
          - test_script
        publish:
          - test_script
        on_complete: lint

      - name: debugStyleError
        kind: debug
        agent: cydebugger
        subscribe:
          - test_script
        publish:
          - test_script
        on_complete: runTests

      - name: runTests
        kind: execute
        agent: cypressExec
        subscribe:
          - test_script
        publish:
          - test_results
        retry: 3
        routes:
          - if: "!state.failed" then: endSuccess
          - if: "state.failed" then: debugTestFailure

      - name: debugTestFailure
        kind: debug
        agent: cydebugger
        subscribe:
          - test_script
          - test_results
        publish:
          - test_script
        on_complete: genCode

      // Terminal marker step: no agent, since there's nothing left to
      // execute — it just marks which channel holds the final result.
      - name: endSuccess
        kind: validate
        subscribe:
          - test_results

    max_loops: 4

tasks:
  loginTest:
    workflow: cypressFlow
    inputs:
      given_query: "Write a Cypress test for login page"
    outputs:
      test_plan: memory
      test_script: tests/login.cy.ts
      test_results: reports/test.log